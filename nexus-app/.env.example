# ─────────────────────────────────────────────────────────────────────────────
# NEXUS AI — Environment Variables
# Copy this file to .env.local and fill in your keys
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────────────────────
# Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get from app.tavily.com (free tier available — used for web search)
TAVILY_API_KEY=tvly-your-key-here

# ── Claude Managed Agents (Optional) ────────────────────────────────────────
# Set to "true" to use Claude Managed Agents (Sessions API)
# Leave unset to run in fallback mode (direct anthropic.messages.create)
# Run `npx tsx scripts/setup-agents.ts` to auto-populate the IDs below
MANAGED_AGENTS_ENABLED=false

# Shared environment (optional — leave blank to use default)
NEXUS_ENVIRONMENT_ID=

# ── Sales Agents ─────────────────────────────────────────────────────────────
NEXUS_AGENT_WHY_NOW=
NEXUS_AGENT_CONTACT_INTEL=
NEXUS_AGENT_ICP_SCORER=
NEXUS_AGENT_OUTREACH_WRITER=

# ── Marketing Agents ─────────────────────────────────────────────────────────
NEXUS_AGENT_CONTENT_WRITER=
NEXUS_AGENT_CAMPAIGN_STRATEGIST=
NEXUS_AGENT_SEO_KEYWORD=
NEXUS_AGENT_PERSONALIZATION=
NEXUS_AGENT_ANALYTICS=

# ── Revenue Ops Agents ────────────────────────────────────────────────────────
NEXUS_AGENT_CHURN_PREDICTOR=
NEXUS_AGENT_EXPANSION_INTEL=
NEXUS_AGENT_REVENUE_HEALTH=

# ── Competitive Intelligence Agents ──────────────────────────────────────────
NEXUS_AGENT_PRICING_INTEL=
NEXUS_AGENT_PRODUCT_COMPETITIVE=
NEXUS_AGENT_MARKET_INTEL=

# ── Finance Agents ────────────────────────────────────────────────────────────
NEXUS_AGENT_FINANCIAL_FORECASTING=
NEXUS_AGENT_SPEND_INTEL=

# ── Executive & Brain ─────────────────────────────────────────────────────────
NEXUS_AGENT_EXECUTIVE_INTEL=
NEXUS_AGENT_MASTER_BRAIN=
